// test: @method returning static resolves to the concrete child class
// feature: completion
// Adapted from phpactor virtual_member/virtual-method-returns-static.test
// expect: coolMethod(
---
<?php

/**
 * @method static static sendMessage(string $text)
 */
class Mailer
{
}

class CoolMailer extends Mailer
{
    public function coolMethod(): void {}
}

$coolMailer = new CoolMailer();
$coolMailer->sendMessage('hi')-><>